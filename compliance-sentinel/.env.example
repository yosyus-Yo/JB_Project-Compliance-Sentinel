# Compliance Sentinel React UI local environment.
# Copy to .env.local and fill secrets there. Never commit .env.local.

# Required only for live LLM advisory calls. Without this, the Python engine
# continues to run through deterministic fallback.
OPENAI_API_KEY="sk-..."

# Optional: OpenRouter key for the independent cross-model critic / OpenAI-compatible route.
OPENROUTER_API_KEY="sk-or-..."

# Optional: law.go.kr open API key for Korean statute lookups (deterministic fallback if unset).
LAW_OPEN_API_KEY="..."

# Enable live LLM calls inside the parent Python engine.
CS_ENABLE_LLM_RUNTIME=1

# Promote the LangGraph StateGraph engine to the primary path (deterministic fallback on any failure).
USE_LANGGRAPH=1

# Optional: let structured LLM risk signals affect board diagnostics.
CS_USE_LLM_BOARD_VERDICTS=1

# Speed profile for live LLM calls.
# turbo minimizes LOW/MEDIUM advisory calls; high-risk drafts still run full validation.
CS_LIVE_REVIEW_PROFILE=turbo
CS_LLM_PARALLELISM=8
CS_REVIEW_CACHE_TTL_MS=300000
CS_REVIEW_CACHE_MAX=64

# Optional: choose models available to your OpenAI account.
# The React UI works with any model accepted by the parent Python LLM client.
CS_MODEL_SHALLOW="gpt-5.4-nano"
CS_MODEL_STANDARD="gpt-5.4-mini"
CS_MODEL_DEEP="gpt-5.5"
CS_MODEL_CRITIC="gpt-5.5"

# Optional: Qdrant vector DB URL for RAG (deterministic in-memory fallback if unset/unavailable).
QDRANT_URL="http://localhost:6333"

# Optional server controls.
PYTHON_BIN="python"
CS_PYTHON_TIMEOUT_MS=60000
CS_PYTHON_WORKER_PORT=8765
CS_PYTHON_WORKER_STARTUP_MS=20000
CS_PYTHON_WORKER_TIMEOUT_MS=60000
# CS_DISABLE_REVIEW_CACHE=1
# CS_DISABLE_PYTHON_WORKER=1
# CS_DISABLE_PYTHON_BRIDGE=1
SLACK_WEBHOOK_URL=발급받은_웹훅_URL